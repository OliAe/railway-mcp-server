{
  "name": "@crisog/railway-mcp-server",
  "version": "0.0.2",
  "description": "Unofficial Railway MCP server.",
  "type": "module",
  "mcpName": "io.github.crisog/railway-mcp-server",
  "author": "CrisOG",
  "license": "MIT",
  "keywords": [
    "railway",
    "mcp",
    "modelcontextprotocol",
    "mcp-server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/crisog/railway-mcp-server"
  },
  "packageManager": "bun@1.2.13",
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "railway-mcp-server": "dist/index.js"
  },
  "scripts": {
    "dev": "tsdown --watch --on-success \"chmod +x dist/index.js\"",
    "build": "tsdown && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prepublishOnly": "tsdown && chmod +x dist/index.js",
    "release": "semantic-release",
    "prepare": "node .husky/install.mjs",
    "commitlint": "commitlint"
  },
  "dependencies": {
    "@crisog/railway-sdk": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.20.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.37.0",
    "@types/bun": "latest",
    "@types/node": "^24.9.2",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@semantic-release/github": "^10.3.3",
    "@semantic-release/npm": "^11.0.3",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "3.6.2",
    "semantic-release": "^24.2.3",
    "tsdown": "^0.15.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit'"
    ]
  }
}
